# Copy to ~/App Development/secrets/kmia_paper_research.env on NAS (NOT in git)
# Kalshi public API credentials for price-history ingest (read-only research)

KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=/data/secrets/kalshi_private_key.pem

# WebSocket orderbook archiver (kmia-orderbook-ws container)
KALSHI_WS_ENABLED=true
KALSHI_WS_SNAPSHOT_INTERVAL_SEC=60
KALSHI_WS_ARCHIVE_RAW_DELTAS=true

# Backtest / policy sweep — align P(bin) with live paper loop
KALSHI_BACKTEST_PROB_MODEL=integer_dist_v1
KALSHI_BACKTEST_ORDER_MODE=maker_limit

# Paper execution — maker_limit simulates resting bids (fill when ask <= bid)
PAPER_ORDER_MODE=maker_limit

# Paper trading window — dynamic default (prior-day 10 AM ET through ~1h before expected max).
# 10:00–10:15 ET is typical cheapest entry; use require_cheapest_at_open in policy, not a time lock.
# Set PAPER_TRADING_WINDOW=anchor_only only for debug (15-minute wall-clock gate).
PAPER_TRADING_WINDOW=dynamic
PAPER_LOOP_ANCHOR_ONLY=0
# PAPER_STRICT_MARKET_AGREEMENT=1
# MAX_OBS_AGE_MINUTES=90
# PAPER_MIN_CALIBRATED_EDGE_FLOOR=0.03
