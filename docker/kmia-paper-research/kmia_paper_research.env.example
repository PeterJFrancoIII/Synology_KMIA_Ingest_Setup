# Copy to ~/App Development/secrets/kmia_paper_research.env on NAS (NOT in git)
# Kalshi public API credentials for price-history ingest (read-only research)

KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=/data/secrets/kalshi_private_key.pem

# WebSocket orderbook archiver (kmia-orderbook-ws container)
KALSHI_WS_ENABLED=true
KALSHI_WS_SNAPSHOT_INTERVAL_SEC=60
KALSHI_WS_ARCHIVE_RAW_DELTAS=true
